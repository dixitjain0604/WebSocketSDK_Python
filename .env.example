# Copy these into Railway → Service → Variables

# Required: generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=your-secret-key-here

# Required for POST forms over HTTPS (user management, logs, etc.)
# Space-separated list of your public URL(s).
# If RAILWAY_PUBLIC_DOMAIN is set by Railway, this is auto-derived — but setting
# it explicitly is safer and supports custom domains.
# Example: CSRF_TRUSTED_ORIGINS=https://myapp.up.railway.app https://myapp.com
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app

# Set automatically by Railway — do not override
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
# PORT=8000

# Optional overrides
# DJANGO_SETTINGS_MODULE=demosite.settings.production
# DEVICEBROKER_ADDRESS=127.0.0.1:8002
