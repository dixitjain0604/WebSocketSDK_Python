# Copy these into Railway → Service → Variables

# Required: generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=your-secret-key-here

# Set automatically by Railway — do not override
# RAILWAY_ENVIRONMENT=production
# PORT=8000

# Optional overrides
# DJANGO_SETTINGS_MODULE=demosite.settings.production
# DEVICEBROKER_ADDRESS=127.0.0.1:8002
